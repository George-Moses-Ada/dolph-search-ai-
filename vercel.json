{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dolph-search-ai.onrender.com/api/$1"
    },
    {
      "src": "/(login|signup|settings|help|plans|search-results|images|history|new-chat)",
      "dest": "/$1.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.html"
    }
  ]
}
