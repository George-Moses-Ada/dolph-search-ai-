{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static",
      "config": {
        "distDir": ""
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dolph-search-ai.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
