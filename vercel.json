{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static",
      "config": {
        "distDir": ""
      }
    }
  ],
  "routes": [
    {
      "src": "/server/package.json",
      "dest": "/api"
    }
  ],
  "functions": {
    "server/server.js": {
      "maxDuration": 30
    }
  }
}
